{
  "expo": {
    "name": "Frontline LXP",
    "slug": "frontline-lxp",
    "version": "1.0.0",
    "scheme": "frontline-lxp",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#B04500"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.learningpool.frontlinelxp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#B04500"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.learningpool.frontlinelxp"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
