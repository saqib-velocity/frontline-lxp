{
  "name": "frontline-lxp",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --clear",
    "android": "expo start --android --clear",
    "ios": "expo start --ios --clear",
    "web": "expo start --web --clear",
    "build:web": "expo export --platform web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "scorm:serve": "npx serve /tmp/scorm-content/ShiftUp_Alpha -l 3001 --cors",
    "scorm:deploy:shiftup": "cd /tmp/scorm-content/ShiftUp_Alpha && vercel deploy --prod",
    "scorm:deploy:check-label": "cd /tmp/scorm-content/CheckTheLabel && vercel deploy --prod",
    "scorm:deploy:setting-tone": "cd /tmp/scorm-content/SettingTheTone && vercel deploy --prod",
    "scorm:deploy:engaging-safely": "cd /tmp/scorm-content/EngagingSafely && vercel deploy --prod",
    "scorm:deploy:retail-stress": "cd /tmp/scorm-content/RetailStressToolkit && vercel deploy --prod"
  },
  "dependencies": {
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo/ngrok": "^4.1.0",
    "@expo/vector-icons": "^15.1.1",
    "@tanstack/react-query": "^5.99.0",
    "clsx": "^2.1.1",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-screen-orientation": "~9.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "^55.0.17",
    "typescript": "~5.9.2"
  },
  "private": true
}
