{
  "name": "frontline-lxp",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --clear",
    "android": "expo start --android --clear",
    "ios": "expo start --ios --clear",
    "web": "expo start --web --clear",
    "build:web": "expo export --platform web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "scorm:serve": "npx serve /tmp/scorm-content/ShiftUp_Alpha -l 3001 --cors",
    "scorm:deploy:shiftup": "cd /tmp/scorm-content/ShiftUp_Alpha && vercel deploy --prod",
    "scorm:deploy:check-label": "cd /tmp/scorm-content/CheckTheLabel && vercel deploy --prod",
    "scorm:deploy:setting-tone": "cd /tmp/scorm-content/SettingTheTone && vercel deploy --prod",
    "scorm:deploy:engaging-safely": "cd /tmp/scorm-content/EngagingSafely && vercel deploy --prod",
    "scorm:deploy:retail-stress": "cd /tmp/scorm-content/RetailStressToolkit && vercel deploy --prod"
  },
  "dependencies": {
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo/ngrok": "^4.1.0",
    "@expo/vector-icons": "^15.1.1",
    "@tanstack/react-query": "^5.99.0",
    "clsx": "^2.1.1",
    "expo": "~55.0.0",
    "expo-blur": "~55.0.14",
    "expo-constants": "~55.0.15",
    "expo-dev-client": "~55.0.28",
    "expo-file-system": "~55.0.17",
    "expo-font": "~55.0.6",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.14",
    "expo-notifications": "~55.0.20",
    "expo-router": "~55.0.13",
    "expo-screen-orientation": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-updates": "~55.0.21",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~55.0.8",
    "typescript": "~5.9.2"
  },
  "private": true
}
